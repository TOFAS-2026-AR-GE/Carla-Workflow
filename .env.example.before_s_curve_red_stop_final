HOST=127.0.0.1
PORT=2000
TIMEOUT=60.0
VEHICLE_NAME=vehicle.tesla.model3
SCENARIO_FILE=scenarios/traffic.yaml
FIXED_DELTA_SECONDS=0.05
SAVE_EVERY_N_FRAMES=5
PERCEPTION_EVERY_N_FRAMES=2
OUTPUT_FOLDER=data/runs
ENABLE_DATA_RECORDING=false

CAMERA_WIDTH=800
CAMERA_HEIGHT=600
CAMERA_FOV=90

# The bundled YOLO model is expected to contain:
# bike, motobike, traffic_light_green, traffic_light_orange,
# traffic_light_red, traffic_sign_30/60/90, vehicle.
VEHICLE_MODEL=models/vehicle/carla_yolov8n_best.pt
VEHICLE_DEVICE=auto
VEHICLE_CONFIDENCE=0.15
VEHICLE_IMAGE_SIZE=640

# Optional separate traffic-sign pipeline. It is not needed for traffic lights.
SIGN_DETECTOR_MODEL=models/signs/detector.onnx
SIGN_CLASSIFIER_MODEL=models/signs/classifier.onnx
SIGN_CLASS_NAMES=models/signs/class_names.json
SIGN_DEVICE=cpu
ENABLE_SIGN_DETECTION=false
SIGN_DETECTOR_CONFIDENCE=0.25
SIGN_DETECTOR_IOU=0.50
SIGN_CLASSIFIER_CONFIDENCE=0.50
SIGN_DETECTOR_IMAGE_SIZE=512
SIGN_CLASSIFIER_IMAGE_SIZE=96

STATUS_PERIOD_SECONDS=1.0
MAX_RUNTIME_SECONDS=0
MAXIMUM_SPEED_KMH=60

# Random step-reference experiment. The speed planner converts each step into
# a comfortable acceleration/deceleration ramp before it reaches the pedals.
ENABLE_RANDOM_REFERENCE_SPEED=false
REFERENCE_MIN_SPEED_KMH=15
REFERENCE_MAX_SPEED_KMH=55
REFERENCE_INITIAL_SPEED_KMH=30
REFERENCE_MIN_HOLD_SECONDS=6
REFERENCE_MAX_HOLD_SECONDS=12
REFERENCE_SEED=7

# 10 m is the base comfort gap. A small margin prevents pedal chatter.
FOLLOW_GAP_M=10.0
FOLLOW_GAP_MARGIN_M=1.5

# Colour comes from the trained camera model. CARLA geometry supplies stop-line
# distance. Set fallback=true only while debugging a weak light classifier.
TRAFFIC_LIGHT_GROUND_TRUTH_FALLBACK=false
TRAFFIC_LIGHT_MAX_DISTANCE_M=70

DASHBOARD_HISTORY_SECONDS=20
