"""Kamera rengi ve CARLA durma çizgisi geometrisiyle trafik ışığı gözlemcisi."""

from __future__ import annotations

from collections import deque
import math

from carla_app.controller.vehicle.smooth_stop_planner import SmoothStopPlanner


def clamp(value: float, minimum: float, maximum: float) -> float:
    return max(minimum, min(value, maximum))


class TrafficLightObserver:
    """Kırmızı ışığı kararlı biçimde kilitler ve durma çizgisi üretir.

    Işığın rengi kamera modelinden alınır. CARLA aktörü yalnızca ilgili durma
    çizgisinin rota üzerindeki mesafesini bulmak için kullanılır. Bir kez
    güvenilir kırmızı kararı verildikten sonra tek karelik algılama kaybında
    fren planı bırakılmaz; açık ve doğrulanmış yeşil görülene kadar kırmızı
    taahhüdü korunur.
    """

    VALID_STATES = {"red", "yellow", "green", "unknown"}

    def __init__(
        self,
        dt: float,
        image_width: int,
        image_height: int,
        use_ground_truth_state_fallback: bool = False,
        maximum_distance_m: float = 140.0,
    ) -> None:
        self.dt = max(1e-3, float(dt))
        self.image_width = max(1, int(image_width))
        self.image_height = max(1, int(image_height))
        self.use_ground_truth_state_fallback = bool(
            use_ground_truth_state_fallback
        )
        self.maximum_distance_m = max(20.0, float(maximum_distance_m))

        self.maximum_perception_age_frames = max(
            1,
            int(round(0.60 / self.dt)),
        )
        self.vote_window = deque(maxlen=max(5, int(round(0.45 / self.dt))))
        self.red_confirmation_votes = 2
        self.green_confirmation_votes = 2
        self.yellow_confirmation_votes = 2
        self.high_speed_single_vote_mps = 18.0
        self.high_speed_single_vote_confidence = 0.78

        self.confirmed_state = "unknown"
        self.red_committed = False
        self.last_detection_frame_id = None
        self.last_confidence = 0.0
        self.last_bbox = None

        self.traffic_light_actors = None
        self.current_actor_id = None
        self.filtered_distance_m = None
        self.last_raw_distance_m = None

        self.stop_gap_m = 1.20
        self.comfort_peak_deceleration_mps2 = 1.80
        self.comfort_jerk_mps3 = 0.90
        self.perception_reserve_s = 0.35
        self.minimum_activation_distance_m = 6.0
        self.activation_margin_m = 1.50

    def update(
        self,
        current_frame_id: int,
        state: dict,
        vehicle,
        world,
        perception_result: dict | None,
    ) -> dict:
        speed_mps = max(0.0, float(state.get("speed_mps", 0.0)))
        detection = self.select_relevant_detection(perception_result)
        detection_fresh = False
        detection_state = "unknown"

        if detection is not None and perception_result is not None:
            detection_frame_id = int(
                perception_result.get("frame_id", current_frame_id)
            )
            age = int(current_frame_id) - detection_frame_id
            detection_fresh = 0 <= age <= self.maximum_perception_age_frames

            if (
                detection_fresh
                and detection_frame_id != self.last_detection_frame_id
            ):
                self.last_detection_frame_id = detection_frame_id
                self.last_confidence = float(
                    detection.get("confidence", 0.0)
                )
                self.last_bbox = tuple(detection.get("bbox", ()))
                detection_state = self.class_name_to_state(
                    detection.get("class_name")
                )
                self._add_vote(
                    detection_state,
                    confidence=self.last_confidence,
                    speed_mps=speed_mps,
                )

        actor, raw_distance_m = self.find_relevant_actor(
            vehicle,
            world,
            state,
        )
        distance_m = self.filter_stop_distance(
            actor=actor,
            raw_distance_m=raw_distance_m,
            speed_mps=speed_mps,
        )
        actor_state = self.actor_state(actor)

        # Kırmızı, durma çizgisi mevcutken bir kontrol taahhüdüdür. Kamera bir
        # iki kare ışığı kaçırınca sanal engel kaybolup gaz-fren salınımı yapmaz.
        if self.confirmed_state == "red" and distance_m is not None:
            self.red_committed = True
        elif self.confirmed_state == "green":
            self.red_committed = False

        if self.red_committed:
            observed_state = "red"
            source = "vision_latched+carla_geometry"
        else:
            observed_state = self.confirmed_state
            source = "vision"

        if (
            observed_state == "unknown"
            and self.use_ground_truth_state_fallback
        ):
            observed_state = actor_state
            source = "carla_state_fallback"
        elif actor is not None and not self.red_committed:
            source = "vision+carla_geometry"

        # Kırmızıya taahhüt edilmemiş durumlarda eski kamera kararı temizlenir.
        if (
            not detection_fresh
            and not self.red_committed
            and self.last_detection_frame_id is not None
        ):
            age = int(current_frame_id) - int(self.last_detection_frame_id)
            if age > self.maximum_perception_age_frames:
                self.vote_window.clear()
                self.confirmed_state = "unknown"
                observed_state = (
                    actor_state
                    if self.use_ground_truth_state_fallback
                    else "unknown"
                )
                source = (
                    "carla_state_fallback"
                    if self.use_ground_truth_state_fallback
                    else "stale"
                )

        requires_stop = self.requires_stop(
            light_state=observed_state,
            distance_m=distance_m,
            speed_mps=speed_mps,
        )

        obstacle = None
        if requires_stop and distance_m is not None:
            obstacle = {
                "track_id": -100,
                "class_name": f"traffic_light_{observed_state}",
                "distance_m": max(0.21, float(distance_m)),
                "lateral_m": 0.0,
                "lead_speed_mps": 0.0,
                "relative_speed_mps": -speed_mps,
                "source": f"traffic_light_{observed_state}",
                "measurement_frame_id": self.last_detection_frame_id,
                "activation_distance_m": self.activation_distance_m(
                    speed_mps
                ),
                "red_committed": self.red_committed,
                "stop_line_id": self.current_actor_id,
            }

        return {
            "state": observed_state,
            "confirmed_vision_state": self.confirmed_state,
            "red_committed": self.red_committed,
            "actor_state": actor_state,
            "distance_m": distance_m,
            "raw_distance_m": raw_distance_m,
            "requires_stop": requires_stop,
            "source": source,
            "confidence": self.last_confidence,
            "bbox": self.last_bbox,
            "measurement_frame_id": self.last_detection_frame_id,
            "activation_distance_m": self.activation_distance_m(speed_mps),
            "stop_line_id": self.current_actor_id,
            "obstacle": obstacle,
        }

    def select_relevant_detection(
        self,
        perception_result: dict | None,
    ) -> dict | None:
        if not perception_result:
            return None

        detections = perception_result.get("traffic_lights", []) or []
        best = None
        best_score = -math.inf

        for detection in detections:
            try:
                x1, y1, x2, y2 = [
                    float(value) for value in detection["bbox"]
                ]
                confidence = float(detection.get("confidence", 0.0))
            except (KeyError, TypeError, ValueError):
                continue

            width = max(0.0, x2 - x1)
            height = max(0.0, y2 - y1)
            if width < 3.0 or height < 5.0:
                continue

            center_x = 0.5 * (x1 + x2)
            center_y = 0.5 * (y1 + y2)
            normalized_x = center_x / self.image_width
            normalized_y = center_y / self.image_height
            if not 0.12 <= normalized_x <= 0.88:
                continue
            if not 0.01 <= normalized_y <= 0.80:
                continue

            centrality = 1.0 - abs(normalized_x - 0.5) / 0.5
            area_ratio = (
                width * height
                / float(self.image_width * self.image_height)
            )
            # Merkezdeki ve daha büyük ışık, uzaktaki yan yol ışığından önce
            # seçilir. Confidence tek başına karar vermez.
            score = (
                2.1 * confidence
                + 1.0 * centrality
                + 22.0 * area_ratio
            )
            if score > best_score:
                best = detection
                best_score = score

        return best

    def _add_vote(
        self,
        state: str,
        confidence: float = 0.0,
        speed_mps: float = 0.0,
    ) -> None:
        if state == "unknown":
            return

        self.vote_window.append(state)

        if state == "red":
            required_votes = self.red_confirmation_votes
            if (
                float(speed_mps) >= self.high_speed_single_vote_mps
                and float(confidence)
                >= self.high_speed_single_vote_confidence
            ):
                required_votes = 1

            if self.vote_window.count("red") >= required_votes:
                self.confirmed_state = "red"
                self.red_committed = True
            return

        if state == "green":
            if self.vote_window.count("green") >= self.green_confirmation_votes:
                self.confirmed_state = "green"
                self.red_committed = False
                self.vote_window.clear()
                self.vote_window.append("green")
            return

        # Sarı, kırmızı taahhüdünü tek başına iptal etmez. Yeşilden sarıya
        # geçişte ise ikili doğrulamayla dilemma-zone kararı verilebilir.
        if (
            state == "yellow"
            and not self.red_committed
            and self.vote_window.count("yellow")
            >= self.yellow_confirmation_votes
        ):
            self.confirmed_state = "yellow"

    def activation_distance_m(self, speed_mps: float) -> float:
        """Konforlu S-eğrisi duruşu için gereken algılama mesafesi."""
        speed_mps = max(0.0, float(speed_mps))
        profile_distance = SmoothStopPlanner.smooth_profile_distance(
            speed_mps,
            self.comfort_peak_deceleration_mps2,
        )
        total = (
            profile_distance
            + speed_mps * self.perception_reserve_s
            + self.stop_gap_m
            + self.activation_margin_m
        )
        return clamp(
            total,
            self.minimum_activation_distance_m,
            self.maximum_distance_m,
        )

    @staticmethod
    def class_name_to_state(class_name) -> str:
        normalized = (
            str(class_name or "")
            .strip()
            .lower()
            .replace("-", "_")
        )
        if "traffic" not in normalized or "light" not in normalized:
            return "unknown"
        if "red" in normalized:
            return "red"
        if (
            "orange" in normalized
            or "yellow" in normalized
            or "amber" in normalized
        ):
            return "yellow"
        if "green" in normalized:
            return "green"
        return "unknown"

    def find_relevant_actor(self, vehicle, world, state: dict):
        candidates = []

        try:
            direct_actor = vehicle.get_traffic_light()
        except (AttributeError, RuntimeError):
            direct_actor = None
        if direct_actor is not None:
            candidates.append(direct_actor)

        if self.traffic_light_actors is None:
            try:
                self.traffic_light_actors = list(
                    world.get_actors().filter("traffic.traffic_light*")
                )
            except (AttributeError, RuntimeError):
                self.traffic_light_actors = []

        candidates.extend(self.traffic_light_actors)

        best_actor = None
        best_distance = None
        visited_ids = set()

        for candidate in candidates:
            if not getattr(candidate, "is_alive", True):
                continue
            actor_id = getattr(candidate, "id", id(candidate))
            if actor_id in visited_ids:
                continue
            visited_ids.add(actor_id)

            # CARLA'nın get_stop_waypoints() çıktısı trafik ışığının gerçek
            # durma çizgisidir. Trigger box merkezi özellikle kavşaklarda birkaç
            # metre sapabildiği için önce bu resmi geometri kullanılır. Eski
            # CARLA sürümleri veya özel haritalar için trigger konumu yedektir.
            stop_locations = self.stop_locations(candidate)
            lane_width = max(2.5, float(state.get("lane_width", 3.5)))

            candidate_distance = None
            for stop_location in stop_locations:
                route_position = self.route_relative_position(
                    stop_location,
                    state,
                )
                if route_position is None:
                    continue

                forward_m, lateral_m = route_position
                if not 0.0 < forward_m <= self.maximum_distance_m:
                    continue
                if abs(lateral_m) > 0.80 * lane_width:
                    continue

                if (
                    candidate_distance is None
                    or forward_m < candidate_distance
                ):
                    candidate_distance = forward_m

            if candidate_distance is None:
                continue

            if best_distance is None or candidate_distance < best_distance:
                best_actor = candidate
                best_distance = candidate_distance

        return best_actor, best_distance

    def filter_stop_distance(
        self,
        actor,
        raw_distance_m: float | None,
        speed_mps: float,
    ) -> float | None:
        """Statik durma çizgisini öngörü + sınırlı düzeltmeyle süzer."""
        actor_id = getattr(actor, "id", None) if actor is not None else None

        if raw_distance_m is None:
            if self.filtered_distance_m is None or not self.red_committed:
                return None
            self.filtered_distance_m = max(
                0.05,
                self.filtered_distance_m - speed_mps * self.dt,
            )
            return self.filtered_distance_m

        raw_distance_m = max(0.05, float(raw_distance_m))
        actor_changed = (
            actor_id is not None
            and self.current_actor_id is not None
            and actor_id != self.current_actor_id
        )

        if self.filtered_distance_m is None or actor_changed:
            self.filtered_distance_m = raw_distance_m
        else:
            predicted_distance_m = max(
                0.05,
                self.filtered_distance_m - speed_mps * self.dt,
            )
            innovation_m = clamp(
                raw_distance_m - predicted_distance_m,
                -2.5,
                2.5,
            )
            self.filtered_distance_m = max(
                0.05,
                predicted_distance_m + 0.32 * innovation_m,
            )

        self.current_actor_id = actor_id
        self.last_raw_distance_m = raw_distance_m
        return self.filtered_distance_m

    @classmethod
    def stop_locations(cls, actor) -> list:
        """Işığın bu şerit için durma noktası adaylarını döndürür."""
        try:
            waypoints = list(actor.get_stop_waypoints() or [])
        except (AttributeError, RuntimeError, TypeError):
            waypoints = []

        locations = []
        for waypoint in waypoints:
            try:
                locations.append(waypoint.transform.location)
            except (AttributeError, RuntimeError):
                continue

        if locations:
            return locations

        fallback = cls.trigger_world_location(actor)
        return [fallback] if fallback is not None else []

    @staticmethod
    def trigger_world_location(actor):
        try:
            transform = actor.get_transform()
            local = actor.trigger_volume.location
            location = type(local)(x=local.x, y=local.y, z=local.z)
            return transform.transform(location)
        except (AttributeError, RuntimeError, TypeError):
            return None

    def route_relative_position(
        self,
        location,
        state: dict,
    ) -> tuple[float, float] | None:
        path = state.get("reference_path", []) or []
        ego = state.get("location")
        if ego is None:
            return None

        if not path:
            yaw = math.radians(float(state.get("yaw", 0.0)))
            dx = float(location.x - ego.x)
            dy = float(location.y - ego.y)
            return (
                math.cos(yaw) * dx + math.sin(yaw) * dy,
                -math.sin(yaw) * dx + math.cos(yaw) * dy,
            )

        points = [ego] + list(path)
        cumulative = 0.0
        best = None

        for index in range(len(points) - 1):
            first = points[index]
            second = points[index + 1]
            vx = float(second.x - first.x)
            vy = float(second.y - first.y)
            length_squared = vx * vx + vy * vy
            if length_squared < 1e-9:
                continue

            wx = float(location.x - first.x)
            wy = float(location.y - first.y)
            parameter = clamp(
                (wx * vx + wy * vy) / length_squared,
                0.0,
                1.0,
            )
            projected_x = first.x + parameter * vx
            projected_y = first.y + parameter * vy
            dx = float(location.x - projected_x)
            dy = float(location.y - projected_y)
            distance_squared = dx * dx + dy * dy
            segment_length = math.sqrt(length_squared)
            cross = (
                vx * (location.y - projected_y)
                - vy * (location.x - projected_x)
            )
            lateral = (
                math.copysign(math.sqrt(distance_squared), cross)
                if distance_squared > 0.0
                else 0.0
            )
            forward = cumulative + parameter * segment_length
            candidate = (distance_squared, forward, lateral)
            if best is None or candidate[0] < best[0]:
                best = candidate
            cumulative += segment_length

        if best is None:
            return None
        return float(best[1]), float(best[2])

    @staticmethod
    def actor_state(actor) -> str:
        if actor is None:
            return "unknown"
        try:
            text = str(actor.get_state()).lower()
        except (AttributeError, RuntimeError):
            return "unknown"
        if "red" in text:
            return "red"
        if "yellow" in text or "orange" in text:
            return "yellow"
        if "green" in text:
            return "green"
        return "unknown"

    def requires_stop(
        self,
        light_state: str,
        distance_m: float | None,
        speed_mps: float,
    ) -> bool:
        if distance_m is None:
            return False

        distance_m = float(distance_m)
        if not 0.0 < distance_m <= self.maximum_distance_m:
            return False

        if light_state == "red":
            return distance_m <= self.activation_distance_m(speed_mps)

        if light_state != "yellow":
            return False

        # Sarıda yalnız konforlu biçimde durabilecek mesafe varsa dur; dilemma
        # zone içinde son anda sert fren başlatma.
        yellow_stop_distance_m = (
            SmoothStopPlanner.stopping_distance(
                max(0.0, float(speed_mps)),
                2.20,
                1.40,
            )
            + self.stop_gap_m
        )
        return distance_m >= yellow_stop_distance_m
