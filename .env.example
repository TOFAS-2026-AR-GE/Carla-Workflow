HOST=127.0.0.1
PORT=2000
TIMEOUT=60.0
VEHICLE_NAME=vehicle.tesla.model3
EGO_ROLE_NAME=ego_vehicle
SCENARIO_FILE=scenarios/traffic.yaml
FIXED_DELTA_SECONDS=0.05
SAVE_EVERY_N_FRAMES=5
# auto: GPU/VRAM ve canlı inference yüküne göre bu değerleri kendisi seçer.
# manual: aşağıdaki kare aralığı, bekleme ve görüntü boyutu değerlerini kullanır.
PERFORMANCE_PROFILE=auto
PERCEPTION_EVERY_N_FRAMES=2
MAXIMUM_PERCEPTION_PERIOD=3
CAMERA_WAIT_TIMEOUT_MS=10
OUTPUT_FOLDER=data/runs
ENABLE_DATA_RECORDING=false
# Her mod 15 sensor + BEV dogrulamasi kullanir; record ayrica diske kaydeder.
# control/record: tek on-kamera inference, OpenCV'de BEV paneli yoktur.
# bev: yedi-kamera inference, IPM ve OpenCV BEV paneli aktiftir.
SENSOR_MODE=control
# Gerekirse mod varsayilanlarini ayri ayri ezmek icin:
# SHOW_BEV_PANEL=true
# ENABLE_MULTICAMERA_PERCEPTION=true
BEV_UPDATE_EVERY_N_FRAMES=2
BEV_WIDTH=800
BEV_HEIGHT=600
PERCEPTION_LATENCY_BUDGET_MS=80
CAMERA_INFERENCE_BATCH_SIZE=4

# ufld_carla_best.pth egitim geometrisi.
CAMERA_WIDTH=1640
CAMERA_HEIGHT=590
CAMERA_FOV=150
SURROUND_CAMERA_WIDTH=640
SURROUND_CAMERA_HEIGHT=360
# Yalnız OpenCV pencere boyutudur; UFLD kamera geometrisini değiştirmez.
DASHBOARD_WIDTH=1500
DASHBOARD_HEIGHT=600
NAVIGATION_SPEED_KMH=45
NAVIGATION_ARRIVAL_DISTANCE_M=2.5
NAVIGATION_RENDER_EVERY_N_FRAMES=4

VEHICLE_MODEL=models/vehicle/carla_yolov8n_best.pt
SIGN_DETECTOR_MODEL=models/signs/detector.onnx
SIGN_CLASSIFIER_MODEL=models/signs/classifier.onnx
SIGN_CLASS_NAMES=models/signs/class_names.json
LANE_MODEL=models/lane/ufld_carla_best.pth

VEHICLE_DEVICE=auto
SIGN_DEVICE=auto
LANE_DEVICE=auto
ENABLE_FP16_INFERENCE=true
ENABLE_SIGN_DETECTION=false
ENABLE_LANE_DETECTION=true
ENABLE_LIDAR_FUSION=true
VEHICLE_CONFIDENCE=0.05
SIGN_DETECTOR_CONFIDENCE=0.25
SIGN_DETECTOR_IOU=0.50
SIGN_CLASSIFIER_CONFIDENCE=0.50
VEHICLE_IMAGE_SIZE=640
SIGN_DETECTOR_IMAGE_SIZE=512
SIGN_CLASSIFIER_IMAGE_SIZE=96
LANE_CONFIDENCE=0.15
LANE_MINIMUM_POINTS=3
STATUS_PERIOD_SECONDS=2.0
MAX_RUNTIME_SECONDS=0
MAXIMUM_SPEED_KMH=70
